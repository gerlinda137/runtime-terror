#!/bin/sh

BRANCH=$(git rev-parse --abbrev-ref HEAD)
PATTERN="^(feature|bugfix|hotfix|chore|release|refactor|docs)\/[a-z0-9][a-z0-9\-]*$"

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "develop" ]; then
  npx lint-staged
  exit 0
fi

if ! echo "$BRANCH" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Branch name '$BRANCH' doesn't match the naming convention."
  echo ""
  echo "Expected format: <type>/<description>"
  echo "  feature/add-login-page"
  echo "  bugfix/fix-header-scroll"
  echo "  chore/update-deps"
  echo "  docs/sprint-diary"
  echo ""
  echo "Rename your branch:"
  echo "  git branch -m <new-name>"
  echo ""
  exit 1
fi

npx lint-staged